# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules

# Yarn - see https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*


# local envs
.turbo
.env*

# testing
coverage

# next.js
.next/
out/
build

# misc
.eslintcache
.DS_Store
.react-templates
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

